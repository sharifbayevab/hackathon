# Postgres (used both by docker-compose and by the app)
POSTGRES_USER=leaderboard
POSTGRES_PASSWORD=leaderboard
POSTGRES_DB=leaderboard

# App config
DATABASE_URL=postgresql+psycopg2://leaderboard:leaderboard@localhost:5432/leaderboard
SECRET_KEY=please-change-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
